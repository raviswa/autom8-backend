# ============================================================================
# AUTOM8 BACKEND - ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env and fill in your actual values

# Server
PORT=3001
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase

# Frontend URL (password reset links, CORS). In production use https://app.autom8.works
FRONTEND_URL=https://app.autom8.works

# Facebook OAuth (Optional)
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# JWT Token Expiration
JWT_EXPIRATION=24h
REFRESH_TOKEN_EXPIRATION=7d

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/autom8

# Logging
LOG_LEVEL=info

# Features
ENABLE_WEBSOCKET=true
ENABLE_REALTIME=true

# Internal service auth (must match on api + chat Railway services)
AUTOM8_KDS_SECRET=generate-a-long-random-string

# Chat service (Node webhook proxy → Python)
CHAT_SERVICE_URL=https://chat.autom8.works
META_WEBHOOK_VERIFY_TOKEN=your-meta-verify-token

# ── Razorpay (chat service only — restaurant payment links) ───────────────────
# Test keys from Razorpay Dashboard → Settings → API Keys (mode: Test)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_test_key_secret
# Optional: Dashboard → Webhooks → secret (recommended for /webhook/razorpay)
RAZORPAY_WEBHOOK_SECRET=
# Where customers land after paying (defaults to chat /payment/complete)
RAZORPAY_CALLBACK_URL=https://chat.autom8.works/payment/complete
CHAT_PUBLIC_URL=https://chat.autom8.works
